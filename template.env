# SUPABASE CONFIGURATION
# 1. Get your URL and API Key from project settings -> API
# 2. Key should be the service_role key to allow bucket management

SUPABASE_URL=https://your-url.supabase.co
SUPABASE_KEY=your-service-role-key
  
# 3. Use the name of the bucket you created in Supabase Storage
SUPABASE_BUCKET=videos

# ANALYSIS CONFIGURATION (Optional Templates)
ANNOTATION_FPS=None
PIXEL_TO_METRIC_SCALE=0.002
